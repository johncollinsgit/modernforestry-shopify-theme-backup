{%- assign support_email = section.settings.support_email | default: shop.email | strip -%}
{%- assign support_phone = section.settings.support_phone | default: shop.phone | strip -%}
{%- assign business_address = section.settings.business_address | strip -%}
{%- if business_address == blank and shop.address != blank -%}
  {%- capture business_address -%}
    {%- if shop.address.address1 != blank -%}{{ shop.address.address1 }}{%- endif -%}
    {%- if shop.address.address2 != blank -%}{{ '\n' }}{{ shop.address.address2 }}{%- endif -%}
    {%- if shop.address.city != blank or shop.address.province != blank or shop.address.zip != blank -%}
      {{ '\n' }}{{ shop.address.city }}{%- if shop.address.province_code != blank -%}, {{ shop.address.province_code }}{%- elsif shop.address.province != blank -%}, {{ shop.address.province }}{%- endif -%}{% if shop.address.zip != blank %} {{ shop.address.zip }}{% endif %}
    {%- endif -%}
    {%- if shop.address.country != blank -%}{{ '\n' }}{{ shop.address.country }}{%- endif -%}
  {%- endcapture -%}

  {%- assign business_address = business_address | strip -%}
{%- endif -%}

{%- assign should_render_support_panel = false -%}
{%- if support_email != blank or support_phone != blank or business_address != blank or section.settings.support_hours != blank -%}
  {%- assign should_render_support_panel = true -%}
{%- endif -%}

<div class="Container">
  <header class="PageHeader">
    <div class="SectionHeader SectionHeader--center">
      <h1 class="SectionHeader__Heading Heading u-h1">{{ page.title }}</h1>
    </div>
  </header>

  <div class="PageContent PageContent--narrow">
    <div class="Rte">
      {{- page.content -}}

      {%- if should_render_support_panel -%}
        <div class="Segment">
          <h2 class="Segment__Title Heading u-h5">{{ section.settings.support_heading | default: 'Contact details' | escape }}</h2>

          <ul class="Linklist Linklist--spacingLoose">
            {%- if support_email != blank -%}
              <li class="Linklist__Item"><strong>Email:</strong> <a class="Link Link--primary" href="mailto:{{ support_email | escape }}" style="color: inherit;">{{ support_email | escape }}</a></li>
            {%- endif -%}

            {%- if support_phone != blank -%}
              {%- assign support_phone_href = support_phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | remove: '.' -%}
              <li class="Linklist__Item"><strong>Phone:</strong> <a class="Link Link--primary" href="tel:{{ support_phone_href | escape }}" style="color: inherit;">{{ support_phone | escape }}</a></li>
            {%- endif -%}

            {%- if business_address != blank -%}
              <li class="Linklist__Item"><strong>Address:</strong> {{ business_address | escape | newline_to_br }}</li>
            {%- endif -%}

            {%- if section.settings.support_hours != blank -%}
              <li class="Linklist__Item"><strong>Hours:</strong> {{ section.settings.support_hours | escape }}</li>
            {%- endif -%}
          </ul>
        </div>
      {%- endif -%}

      {%- form 'contact', class: 'Form Form--spacingTight' -%}
        {%- if form.posted_successfully? -%}
          <p class="Alert Alert--success">{{ 'contact.form.successfully_sent' | t }}</p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="Form__Alert Alert Alert--error">
            <ul class="Alert__ErrorList">
              {%- for field in form.errors -%}
                {%- if field == 'form' -%}
                  <li class="Alert__ErrorItem">{{ form.errors.messages[field] }}</li>
                {%- else -%}
                  <li class="Alert__ErrorItem"><strong>{{ form.errors.translated_fields[field] }}</strong> {{ form.errors.messages[field] }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}

        <div class="Form__Group">
          <div class="Form__Item">
            <input type="text" class="Form__Input" name="contact[name]" aria-label="{{ 'contact.form.name' | t }}" placeholder="{{ 'contact.form.name' | t }}" required {% if customer %}value="{{ customer.name }}"{% endif %}>
            <label class="Form__FloatingLabel">{{ 'contact.form.name' | t }}</label>
          </div>

          <div class="Form__Item">
            <input type="email" class="Form__Input" name="contact[email]" aria-label="{{ 'contact.form.email' | t }}" placeholder="{{ 'contact.form.email' | t }}" required {% if customer %}value="{{ customer.email }}"{% endif %}>
            <label class="Form__FloatingLabel">{{ 'contact.form.email' | t }}</label>
          </div>
        </div>

        {%- for block in section.blocks -%}
          {%- assign field_title = block.settings.title -%}

          {%- if field_title == blank -%}
            {%- capture field_title -%}Custom field {% increment custom_field %}{%- endcapture -%}
          {%- endif -%}

          {%- if block.type == 'text' -%}
            <div class="Form__Item">
              {%- if block.settings.use_long_text -%}
                <textarea name="contact[{{ field_title | escape }}]" cols="30" rows="10" class="Form__Textarea" aria-label="{{ block.settings.title | escape }}" placeholder="{{ block.settings.title | escape }}" {% if block.settings.is_required %}required{% endif %}></textarea>
                <label class="Form__FloatingLabel">{{ block.settings.title | escape }}</label>
              {%- else -%}
                <input type="text" class="Form__Input" name="contact[{{ field_title | escape }}]" aria-label="{{ block.settings.title | escape }}" placeholder="{{ block.settings.title | escape }}" {% if block.settings.is_required %}required{% endif %}>
                <label class="Form__FloatingLabel">{{ block.settings.title | escape }}</label>
              {%- endif -%}
            </div>
          {%- elsif block.type == 'dropdown' -%}
            {%- assign values = block.settings.values | split: ',' -%}

            {%- if values == empty -%}
              {%- continue -%}
            {%- endif -%}

            <div class="Form__Item">
              <div class="Form__Select Select Select--primary">
                {%- render 'icon' with 'select-arrow' -%}

                <select name="contact[{{ field_title | escape }}]" title="{{ block.settings.title | escape }}" required>
                  <option value="" disabled selected>{{ block.settings.title | escape }}</option>

                  {%- for value in values -%}
                    {%- assign trim_value = value | strip -%}

                    <option value="{{ trim_value | escape }}">{{ trim_value | escape }}</option>
                  {%- endfor -%}
                </select>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}

        <div class="Form__Item">
          <textarea name="contact[body]" cols="30" rows="10" class="Form__Textarea" aria-label="{{ 'contact.form.message' | t }}" placeholder="{{ 'contact.form.message' | t }}" required></textarea>
          <label class="Form__FloatingLabel">{{ 'contact.form.message' | t }}</label>
        </div>

        <button type="submit" class="Form__Submit Button Button--primary Button--full">{{ 'contact.form.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    {
      "type": "header",
      "content": "Customer support"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Heading",
      "default": "Contact details"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "info": "Leave blank to use your Shopify store email."
    },
    {
      "type": "text",
      "id": "support_phone",
      "label": "Support phone",
      "info": "Leave blank to use your Shopify store phone."
    },
    {
      "type": "textarea",
      "id": "business_address",
      "label": "Business address",
      "info": "Leave blank to use your Shopify store address."
    },
    {
      "type": "text",
      "id": "support_hours",
      "label": "Support hours (optional)",
      "info": "Example: Mon–Fri, 9am–5pm ET"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text field",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Custom field"
        },
        {
          "type": "checkbox",
          "id": "use_long_text",
          "label": "Use long text",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "is_required",
          "label": "Field is required",
          "default": false
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "Dropdown",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Name",
          "default": "Custom field"
        },
        {
          "type": "text",
          "id": "values",
          "label": "Values",
          "info": "Separate each value by a comma.",
          "default": "value 1, value 2, value 3"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "text",
        "settings": {
          "title": "Your phone (optional)"
        }
      }
    ]
  }
}
{% endschema %}
