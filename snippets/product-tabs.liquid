{%- assign forestry_reviews_tab_rendered = false -%}
{%- assign forestry_non_review_tab_rendered = false -%}
{%- assign forestry_native_reviews_enabled = settings.native_reviews_enabled -%}
{%- assign forestry_reviews_tab_enabled = forestry_native_reviews_enabled -%}

{%- capture product_tabs -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'content' -%}
        {%- if block.settings.page != blank -%}
          {%- assign title = block.settings.page.title -%}
          {%- assign content = block.settings.page.content -%}
        {%- else -%}
          {%- assign title = block.settings.title -%}
          {%- assign content = block.settings.content -%}
        {%- endif -%}

        {%- if title != blank and content != blank -%}
          {%- assign forestry_non_review_tab_rendered = true -%}
          <div class="Collapsible Collapsible--large" {{ block.shopify_attributes }}>
            <button class="Collapsible__Button Heading u-h6" data-action="toggle-collapsible" aria-expanded="false">
              {{- title -}} <span class="Collapsible__Plus"></span>
            </button>

            <div class="Collapsible__Inner">
              <div class="Collapsible__Content">
                <div class="Rte">
                  {{- content -}}
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}

      {%- when 'reviews' -%}
        {%- if forestry_reviews_tab_enabled -%}
          {%- assign forestry_reviews_tab_rendered = true -%}
          <div class="Collapsible Collapsible--large" {{ block.shopify_attributes }}>
            <button class="Collapsible__Button Heading u-h6" data-action="toggle-collapsible" aria-expanded="false">
              <span>
                {{ 'product.tabs.reviews' | t }}
                {%- if forestry_native_reviews_enabled -%}
                  <span class="text--light">(<span data-forestry-product-review-count data-forestry-product-review-key="{{ product.id }}">0</span>)</span>
                {%- endif -%}
              </span>
              <span class="Collapsible__Plus"></span>
            </button>

            <div class="Collapsible__Inner">
              <div class="Collapsible__Content">
                <div class="ForestryProductReviewsCallout">
                  <p class="Heading u-h6">Product reviews now open in the sitewide drawer.</p>
                  <p class="Text--subdued">Open this product's reviews from the left-side Reviews tab, then use the in-drawer See all reviews action for the full studio feed.</p>
                  <div class="ForestryProductReviewsCallout__actions">
                    <button type="button" class="Button Button--secondary" data-action="forestry-sitewide-reviews-show-product">Open product reviews</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
    {%- endcase -%}
  {%- endfor -%}

  {%- if forestry_reviews_tab_rendered == false and forestry_non_review_tab_rendered == false and forestry_reviews_tab_enabled -%}
    <div class="Collapsible Collapsible--large">
      <button class="Collapsible__Button Heading u-h6" data-action="toggle-collapsible" aria-expanded="false">
        <span>
          {{ 'product.tabs.reviews' | t }}
          {%- if forestry_native_reviews_enabled -%}
            <span class="text--light">(<span data-forestry-product-review-count data-forestry-product-review-key="{{ product.id }}">0</span>)</span>
          {%- endif -%}
        </span>
        <span class="Collapsible__Plus"></span>
      </button>

      <div class="Collapsible__Inner">
        <div class="Collapsible__Content">
          <div class="ForestryProductReviewsCallout">
            <p class="Heading u-h6">Product reviews now open in the sitewide drawer.</p>
            <p class="Text--subdued">Open this product's reviews from the left-side Reviews tab, then use the in-drawer See all reviews action for the full studio feed.</p>
            <div class="ForestryProductReviewsCallout__actions">
              <button type="button" class="Button Button--secondary" data-action="forestry-sitewide-reviews-show-product">Open product reviews</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}
{%- endcapture -%}

{%- if product_tabs != blank -%}
  <div class="Product__Tabs">
    {{- product_tabs -}}
  </div>
{%- endif -%}
