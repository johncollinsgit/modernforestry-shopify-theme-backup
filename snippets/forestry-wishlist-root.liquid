{%- if settings.native_wishlist_enabled -%}
  {%- assign forestry_wishlist_marketing_profile_id = customer.metafields.custom.marketing_profile_id.value | default: '' -%}
  {%- assign forestry_wishlist_compact = compact | default: false -%}
  {%- assign button_classes = 'ForestryWishlistRoot__button' -%}
  {%- if forestry_wishlist_compact -%}
    {%- assign button_classes = button_classes | append: ' ForestryWishlistRoot__button--compact ForestryWishlistRoot__button--link' -%}
  {%- else -%}
    {%- assign button_classes = button_classes | append: ' Button Button--secondary' -%}
  {%- endif -%}
  <div
    class="ForestryWishlistRoot{% if forestry_wishlist_compact %} ForestryWishlistRoot--compact{% endif %}"
    data-forestry-wishlist-root
    data-product-id="{{ product.id }}"
    data-product-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-product-handle="{{ product.handle | escape }}"
    data-product-title="{{ product.title | escape }}"
    data-product-url="{{ product.url | escape }}"
    data-marketing-profile-id="{{ forestry_wishlist_marketing_profile_id }}"
    data-customer-email="{{ customer.email | escape }}"
    data-customer-phone="{{ customer.phone | escape }}"
    data-shopify-customer-id="{{ customer.id }}"
    data-customer-first-name="{{ customer.first_name | escape }}"
    data-customer-last-name="{{ customer.last_name | escape }}"
    data-login-url="{{ routes.account_login_url }}"
    data-endpoint-wishlist-status="/apps/forestry/wishlist/status"
    data-endpoint-wishlist-add="/apps/forestry/wishlist/add"
    data-endpoint-wishlist-create-list="/apps/forestry/wishlist/lists/create"
    data-endpoint-wishlist-remove="/apps/forestry/wishlist/remove"
    data-wishlist-limit="25"
  >
    <button type="button" class="{{ button_classes }}" data-action="forestry-wishlist-toggle" aria-pressed="false">
      <span class="ForestryWishlistRoot__icon ForestryWishlistRoot__icon--outline">
        {%- render 'icon', icon: 'heart' -%}
      </span>
      <span class="ForestryWishlistRoot__icon ForestryWishlistRoot__icon--filled" aria-hidden="true">
        {%- render 'icon', icon: 'heart-filled' -%}
      </span>
      <span data-forestry-wishlist-button-label>{% if forestry_wishlist_compact %}Add to wishlist{% else %}Save to wishlist{% endif %}</span>
    </button>
    <p class="ForestryWishlistRoot__note Text--subdued" data-forestry-wishlist-note></p>
  </div>
{%- endif -%}
