{%- capture section_settings -%}
{
  "type": {{ settings.cart_type | json }},
  "itemCount": {{ cart.item_count }},
  "drawer": true,
  "hasShippingEstimator": false
}
{%- endcapture -%}
{%- assign cart_subtotal_label = 'cart.general.subtotal' | t -%}
{%- assign cart_subtotal_label_check = cart_subtotal_label | downcase -%}
{%- if cart_subtotal_label == blank or cart_subtotal_label_check contains 'translation missing:' -%}
  {%- assign cart_subtotal_label = 'Subtotal' -%}
{%- endif -%}
{%- assign cart_discount_label = 'cart.general.discount' | t -%}
{%- assign cart_discount_label_check = cart_discount_label | downcase -%}
{%- if cart_discount_label == blank or cart_discount_label_check contains 'translation missing:' -%}
  {%- assign cart_discount_label = 'Discount' -%}
{%- endif -%}
{%- assign forestry_cart_has_wholesale_items = false -%}
{%- assign forestry_cart_has_subscription_items = false -%}
{%- assign forestry_cart_has_one_time_items = false -%}
{%- assign forestry_cart_rewards_eligible_subtotal_cents = 0 -%}
{%- for line_item in cart.items -%}
  {%- capture forestry_cart_line_is_wholesale -%}{% render 'forestry-wholesale-product-state', product: line_item.product %}{%- endcapture -%}
  {%- assign forestry_cart_line_is_wholesale = forestry_cart_line_is_wholesale | strip -%}
  {%- if forestry_cart_line_is_wholesale == 'true' -%}
    {%- assign forestry_cart_has_wholesale_items = true -%}
  {%- endif -%}
  {%- assign forestry_cart_line_is_subscription = false -%}
  {%- if line_item.selling_plan_allocation -%}
    {%- assign forestry_cart_line_is_subscription = true -%}
  {%- endif -%}
  {%- if line_item.properties != empty -%}
    {%- for property in line_item.properties -%}
      {%- if property.first == 'shipping_interval_frequency' or property.first == 'subscription_id' -%}
        {%- assign forestry_cart_line_is_subscription = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
  {%- if forestry_cart_line_is_subscription -%}
    {%- assign forestry_cart_has_subscription_items = true -%}
  {%- else -%}
    {%- assign forestry_cart_has_one_time_items = true -%}
    {%- assign forestry_cart_rewards_eligible_subtotal_cents = forestry_cart_rewards_eligible_subtotal_cents | plus: line_item.final_line_price -%}
  {%- endif -%}
{%- endfor -%}
{%- capture forestry_wholesale_line_sheet_url -%}{% render 'forestry-wholesale-url', key: 'line_sheet' %}{%- endcapture -%}
{%- capture forestry_wholesale_login_url -%}{% render 'forestry-wholesale-url', key: 'login' %}{%- endcapture -%}
{%- assign forestry_wholesale_line_sheet_url = forestry_wholesale_line_sheet_url | strip -%}
{%- assign forestry_wholesale_login_url = forestry_wholesale_login_url | strip -%}

<div id="sidebar-cart" class="Drawer Drawer--fromRight" aria-hidden="true" data-section-id="cart" data-section-type="cart" data-section-settings='{{ section_settings }}'>
  <div class="Drawer__Header Drawer__Header--bordered Drawer__Container">
      <span class="Drawer__Title Heading u-h4">{{ 'cart.general.title' | t }}</span>

      <button class="Drawer__Close Icon-Wrapper--clickable" data-action="close-drawer" data-drawer-id="sidebar-cart" aria-label="{{ 'header.navigation.close_cart' | t }}">
        {%- render 'icon' with 'close' -%}
      </button>
  </div>

  <form class="Cart Drawer__Content" action="{{ routes.cart_url }}" method="POST" novalidate>
    <div class="Drawer__Main" data-scrollable>
      {%- if settings.cart_show_free_shipping_threshold -%}
        {%- assign threshold_in_cents = settings.cart_free_shipping_threshold | times: 100 -%}

        <div class="Cart__ShippingNotice Text--subdued">
          <div class="Drawer__Container">
            {%- if cart.total_price >= threshold_in_cents -%}
              <p>{{- 'cart.general.free_shipping' | t -}}</p>
            {%- else -%}
              {%- capture remaining_amount -%}<span>{{ cart.total_price | minus: threshold_in_cents | abs | money }}</span>{%- endcapture -%}
              <p>{{- 'cart.general.free_shipping_remaining_html' | t: remaining_amount: remaining_amount -}}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if cart.item_count == 0 -%}
        <p class="Cart__Empty Heading u-h5">{{ 'cart.general.empty' | t }}</p>
      {%- else -%}
        <div class="Drawer__Container">
          <input type="hidden" name="attributes[collection_mobile_items_per_row]" value="">
          <input type="hidden" name="attributes[collection_desktop_items_per_row]" value="">

          {% render 'cart-items' %}
        </div>
      {%- endif -%}
    </div>

    {%- unless cart.item_count == 0 -%}
      <div class="Drawer__Footer" data-drawer-animated-bottom>
        {%- if forestry_cart_has_one_time_items -%}
          <div class="ForestryRewardsCartMount">
            {% render 'forestry-rewards-root',
              surface: 'drawer',
              title: 'Candle Cash',
              subtitle: '',
              cart_has_subscription_items: forestry_cart_has_subscription_items,
              cart_has_one_time_items: forestry_cart_has_one_time_items,
              cart_rewards_eligible_subtotal: forestry_cart_rewards_eligible_subtotal_cents
            %}
          </div>
        {%- endif -%}

        {%- capture shipping_and_taxes_notice -%}{{ 'cart.general.shipping_and_taxes_notice' | t }}{%- endcapture -%}

        <div class="Cart__SummaryLines Cart__SummaryLines--drawer">
          <p class="Cart__SummaryLine Cart__SummaryLine--subtotal">
            <span>{{ cart_subtotal_label }}</span>
            <span data-cart-subtotal-display="with_currency">{{ cart.items_subtotal_price | money_with_currency }}</span>
          </p>

          {%- assign cart_discount_total = cart.items_subtotal_price | minus: cart.total_price -%}
          <p
            class="Cart__SummaryLine Cart__SummaryLine--discount{% if cart_discount_total <= 0 %} is-hidden{% endif %}"
            data-cart-discount-row
          >
            <span data-cart-discount-label>
              {%- if cart.cart_level_discount_applications != blank and forestry_cart_has_one_time_items -%}
                Candle Cash Applied
              {%- else -%}
                {{ cart_discount_label }}
              {%- endif -%}
            </span>
            <span>-<span data-cart-discount-display="with_currency">{{ cart_discount_total | money_with_currency }}</span></span>
          </p>
        </div>

        {%- if settings.cart_enable_notes or shipping_and_taxes_notice != blank -%}
          {%- if settings.cart_enable_notes -%}
            {%- if cart.note == blank -%}
              <button type="button" class="Cart__NoteButton" data-action="toggle-cart-note">{{ 'cart.general.add_note' | t }}</button>
            {%- else -%}
              <button type="button" class="Cart__NoteButton" data-action="toggle-cart-note">{{ 'cart.general.edit_note' | t }}</button>
            {%- endif -%}
            <p class="Cart__NoteHelpText Text--subdued">Optional: gift message, requested ship timing, handwritten note, or delivery context.</p>
            <p class="Cart__NotePreview Text--subdued{% if cart.note == blank %} is-hidden{% endif %}" data-cart-note-preview>
              {%- if cart.note != blank -%}
                <span class="Cart__NotePreviewLabel">Saved note:</span> {{ cart.note | strip_html | strip_newlines | escape | truncate: 120 }}
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if shipping_and_taxes_notice != blank -%}
            <p class="Cart__Taxes Text--subdued">{{ shipping_and_taxes_notice }}</p>
          {%- endif -%}

        {%- endif -%}

        {%- if forestry_cart_has_wholesale_items -%}
          <div class="Cart__WholesaleNotice">
            <p class="Cart__Taxes Text--subdued">Wholesale/case-pack items in this cart must be ordered on our wholesale storefront.</p>
            <div class="ButtonGroup ButtonGroup--spacingSmall">
              <a href="{{ forestry_wholesale_line_sheet_url }}" class="Button Button--primary Button--full">Wholesale Line Sheet</a>
              <a href="{{ forestry_wholesale_login_url }}" class="Button Button--secondary Button--full">Wholesale Login</a>
            </div>
          </div>
        {%- else -%}
          <div class="Cart__TermsAgreement" data-cart-terms-wrapper>
            <input
              type="checkbox"
              id="cart-drawer-terms-agree"
              class="Cart__TermsCheckbox"
              data-cart-terms-checkbox
              required
            >
            <label for="cart-drawer-terms-agree" class="Cart__TermsLabel">
              I agree to the <a href="/policies/terms-of-service" target="_blank" rel="noopener">terms and conditions</a>.
            </label>
          </div>
          <button type="submit" name="checkout" class="Cart__Checkout Button Button--primary Button--full" data-cart-checkout-trigger tac-ignore="true">
            <span>{{- 'cart.general.checkout' | t -}}</span>
            <span class="Button__SeparatorDot"></span>
            <span data-cart-total-display="with_currency">{{ cart.total_price | money_with_currency }}</span>
          </button>
        {%- endif -%}

        {%- if settings.cart_enable_notes -%}
          <div class="Cart__OffscreenNoteContainer" aria-hidden="true">
            <label for="cart-note" class="Cart__NoteTitle Heading u-h6">Order notes</label>
            <p class="Cart__NoteHelpText Text--subdued" id="cart-note-help-drawer">Optional: gift message, requested ship timing, handwritten note, or delivery context.</p>

            <div class="Form__Item">
              <textarea class="Cart__Note Form__Textarea" name="note" id="cart-note" rows="4" placeholder="{{ 'cart.general.note_placeholder' | t }}" data-scrollable data-cart-note-input aria-describedby="cart-note-help-drawer">{{ cart.note }}</textarea>
            </div>

            <button type="button" class="Button Button--primary Button--full" data-action="toggle-cart-note">{{ 'cart.general.save_note' | t }}</button>
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}
  </form>
</div>
