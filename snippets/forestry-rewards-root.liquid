      "eligibility": {
        "state": "members_only",
        "locked_message": {% if candle_club_actionable %}"Candle Club only"{% else %}{{ candle_club_lock_message | json }}{% endif %},
        "locked_cta_url": {% if candle_club_actionable %}{{ candle_club_url | json }}{% else %}""{% endif %},
