    }
  ],
  "celebration_state": {
    "enabled": false,
    "headline": "",
    "body": "",
    "amount": 0
  },
  "future_hooks": {
    "personalized_reward_reminders": "",
    "next_best_action": "",
    "segmentation_message": "",
