{%- assign rewards_surface = surface | default: 'page' -%}
{%- assign rewards_title = title | default: 'Candle Cash Central' -%}
{%- assign rewards_subtitle = subtitle | default: 'Earn, track, and redeem Candle Cash.' -%}
{%- assign rewards_page_url = rewards_url | default: '/pages/rewards' -%}
{%- assign rewards_account_url = account_url | default: routes.account_url -%}
{%- assign candle_club_url = candle_club_url | default: '/products/modern-forestry-candle-club-16oz-subscription-with-gifts?selling_plan=11300438275' -%}
{%- assign candle_club_actionable = true -%}
{%- assign candle_club_lock_message = 'Candle Club only' -%}
{%- assign rewards_marketing_profile_id = marketing_profile_id | default: customer.metafields.custom.marketing_profile_id.value | default: '' -%}
{%- assign candle_cash_points = customer.metafields.custom.candle_cash_points.value | default: customer.metafields.custom.candle_cash_balance_points.value | default: 0 -%}
{%- assign candle_cash_amount = customer.metafields.custom.candle_cash_balance_amount.value | default: customer.metafields.custom.candle_cash_balance.value | default: customer.metafields.custom.candle_cash.value | default: 0 -%}
{%- assign candle_cash_expiration_days = customer.metafields.custom.candle_cash_expiration_days.value | default: blank -%}
{%- assign candle_cash_expiring_amount = customer.metafields.custom.candle_cash_expiring_amount.value | default: candle_cash_amount -%}
{%- assign candle_cash_expiration_date = '' -%}
{%- if customer and customer.metafields.custom.candle_cash_expiration_date != blank -%}
  {%- assign candle_cash_expiration_date = customer.metafields.custom.candle_cash_expiration_date.value | date: '%Y-%m-%d' -%}
{%- endif -%}
{%- assign candle_club_member = false -%}
{%- if customer -%}
  {%- if customer.tags contains 'Candle Club' or customer.tags contains 'candle-club' or customer.tags contains 'candle_club' or customer.tags contains 'CandleClub' -%}
    {%- assign candle_club_member = true -%}
  {%- endif -%}
  {%- if customer.metafields.custom.candle_club_member != blank -%}
    {%- assign candle_club_member = customer.metafields.custom.candle_club_member.value -%}
  {%- endif -%}
{%- endif -%}
{%- assign rewards_state = 'unknown_customer' -%}
{%- if customer -%}
  {%- assign rewards_state = 'linked_customer' -%}
{%- endif -%}
{%- capture forestry_rewards_fallback_json -%}
{
  "state": {{ rewards_state | json }},
  "profile_id": {{ customer.id | json }},
  "balance": {
    "raw_points": {{ candle_cash_points | json }},
    "points": {{ candle_cash_points | json }},
    "candle_cash_amount": {{ candle_cash_amount | json }},
    "amount": {{ candle_cash_amount | json }},
    "expires_at": {{ candle_cash_expiration_date | json }},
    "expiration_days": {{ candle_cash_expiration_days | json }},
    "expiring_amount": {{ candle_cash_expiring_amount | json }}
  },
  "redemption_rules": {
    "redeem_increment_dollars": 10,
    "redeem_increment_formatted": "$10",
    "redeem_increment_candle_cash": 10,
    "redeem_increment_candle_cash_formatted": "$10.00 Candle Cash",
