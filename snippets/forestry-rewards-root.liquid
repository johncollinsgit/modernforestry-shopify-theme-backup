    "cta_url": {% if candle_club_actionable %}{{ candle_club_url | json }}{% else %}""{% endif %},
    "cta_text": {% if candle_club_actionable %}"Explore Candle Club"{% else %}{{ candle_club_lock_message | json }}{% endif %},
    "cta_disabled": {% if candle_club_actionable %}false{% else %}true{% endif %},
    "lock_message": {{ candle_club_lock_message | json }}
