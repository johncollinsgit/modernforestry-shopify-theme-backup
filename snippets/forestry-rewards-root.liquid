{%- endcapture -%}
<div
  class="ForestryRewardsRoot ForestryRewardsRoot--{{ rewards_surface }}"
  data-forestry-rewards-root
  data-rewards-build-version="2026-04-09-instagram-comment-1"
  data-theme="cognac-reserve"
  data-surface="{{ rewards_surface }}"
  data-title="{{ rewards_title | escape }}"
  data-subtitle="{{ rewards_subtitle | escape }}"
  data-marketing-profile-id="{{ rewards_marketing_profile_id }}"
  data-customer-email="{{ customer.email | escape }}"
  data-customer-phone="{{ customer.phone | escape }}"
  data-shopify-customer-id="{{ customer.id }}"
  data-customer-first-name="{{ customer.first_name | escape }}"
  data-customer-last-name="{{ customer.last_name | escape }}"
  data-login-url="{{ routes.account_login_url }}"
  data-account-url="{{ rewards_account_url }}"
  data-rewards-url="{{ rewards_page_url }}"
  data-candle-club-url="{{ candle_club_url }}"
  data-candle-club-preview-only="false"
  data-candle-club-lock-message="{{ candle_club_lock_message | escape }}"
  data-order-number="{{ order.name | escape }}"
  data-order-total-amount="{{ order.total_price | divided_by: 100.0 }}"
  data-order-created-at="{{ order.created_at | date: '%s' }}"
  data-endpoint-candle-cash-status="/apps/forestry/candle-cash/status"
  data-endpoint-candle-cash-task-submit="/apps/forestry/candle-cash/tasks/submit"
  data-endpoint-google-review-start="/apps/forestry/google-business/review/start"
  data-endpoint-consent-optin="/apps/forestry/consent/optin"
  data-endpoint-customer-status="/apps/forestry/customer/status"
  data-endpoint-rewards-available="/apps/forestry/rewards/available"
  data-endpoint-rewards-redeem="/apps/forestry/rewards/redeem"
  data-endpoint-rewards-history="/apps/forestry/rewards/history"
  data-endpoint-birthday-status="/apps/forestry/birthday/status"
  data-endpoint-birthday-capture="/apps/forestry/birthday/capture"
  data-endpoint-birthday-claim="/apps/forestry/birthday/claim"
  data-endpoint-rewards-event="/apps/forestry/rewards/event"
>
  <div class="ForestryRewardsRoot__loading">
    <div class="ForestryRewardsRoot__loading-copy">
      <p class="Heading u-h6">{{ rewards_title }}</p>
      <p class="Text--subdued">{{ rewards_subtitle }}</p>
    </div>
    <div class="ForestryRewardsRoot__skeleton" aria-hidden="true">
      <span></span><span></span><span></span>
    </div>
  </div>
  <script type="application/json" data-forestry-rewards-fallback>
    {{- forestry_rewards_fallback_json -}}
  </script>
</div>
