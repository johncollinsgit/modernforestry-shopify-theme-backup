{%- if settings.native_reviews_enabled -%}
  <div
    id="shopify-product-reviews"
    class="ForestryProductReviewsRoot"
    data-forestry-product-reviews-root
    data-forestry-product-review-key="{{ product.id }}"
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle | escape }}"
    data-product-title="{{ product.title | escape }}"
    data-product-url="{{ product.url | escape }}"
    data-customer-email="{{ customer.email | escape }}"
    data-customer-phone="{{ customer.phone | escape }}"
    data-shopify-customer-id="{{ customer.id }}"
    data-customer-first-name="{{ customer.first_name | escape }}"
    data-customer-last-name="{{ customer.last_name | escape }}"
    data-login-url="{{ routes.account_login_url }}"
    data-endpoint-product-review-status="/apps/forestry/product-reviews/status"
    data-endpoint-product-review-submit="/apps/forestry/product-reviews/submit"
  >
    <div class="ForestryProductReviewsRoot__loading">
      <p class="Heading u-h6">Customer reviews</p>
      <p class="Text--subdued">Loading the latest reviews for this product.</p>
    </div>
  </div>
{%- elsif settings.growave_reviews_enabled -%}
  <div class="ForestryProductReviewsRoot__loading">
    <p class="Heading u-h6">Customer reviews</p>
    <p class="Text--subdued">Reviews are currently powered by Growave while native storefront reviews are disabled.</p>
  </div>
{%- else -%}
  <div class="ForestryProductReviewsRoot__loading">
    <p class="Heading u-h6">Customer reviews</p>
    <p class="Text--subdued">Reviews are temporarily unavailable.</p>
  </div>
{%- endif -%}
